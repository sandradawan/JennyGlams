# ---------------------------------------------------------------------------
# Sanity CMS connection.
# Copy this file to `.env.local` and fill in the Project ID from your project.
# Get it at https://www.sanity.io/manage → your project → API → Project ID.
# The site runs fine on mock content until these are set. (Project ID is public.)
# ---------------------------------------------------------------------------

# Read by the website:
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"

# Read by the `sanity` CLI (Studio) — use the same values:
SANITY_STUDIO_PROJECT_ID=""
SANITY_STUDIO_DATASET="production"

# Optional — pin the API date (defaults to 2024-10-01 if omitted)
# NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"
